{
  "name": "siupo-restaurant",
  "version": "1.0.0",
  "description": "Modern restaurant web application built with React 19 and TypeScript",
  "private": true,
  "type": "module",
  "author": {
    "name": "Siupo Restaurant Team",
    "url": "https://github.com/hugn2k4"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hugn2k4/siupo-frontend.git"
  },
  "bugs": {
    "url": "https://github.com/hugn2k4/siupo-frontend/issues"
  },
  "homepage": "https://github.com/hugn2k4/siupo-frontend#readme",
  "keywords": [
    "restaurant",
    "food-ordering",
    "table-reservation",
    "react",
    "typescript",
    "vite",
    "tailwindcss",
    "material-ui",
    "i18n",
    "ecommerce"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "vite --port 3000 --open",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 3001",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css,md}\"",
    "type-check": "tsc --noEmit",
    "prepare": "husky install",
    "postinstall": "npm run prepare",
    "clean": "rimraf dist node_modules/.vite",
    "analyze": "vite build --mode analyze"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/roboto": "^5.2.6",
    "@mui/icons-material": "^7.3.1",
    "@mui/material": "^7.3.2",
    "@tailwindcss/postcss": "^4.1.12",
    "@tailwindcss/vite": "^4.1.12",
    "axios": "^1.11.0",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.23.12",
    "i18next": "^25.6.3",
    "i18next-browser-languagedetector": "^8.2.0",
    "lodash": "^4.17.21",
    "lucide-react": "^0.543.0",
    "postcss": "^8.5.6",
    "react": "^19.1.1",
    "react-datepicker": "^8.8.0",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.64.0",
    "react-i18next": "^16.3.5",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.8.1",
    "use-debounce": "^10.0.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.33.0",
    "@types/lodash": "^4.17.21",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react-swc": "^4.0.1",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.3"
  },
  "lint-staged": {
    "*.{json,md,css,scss}": [
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
